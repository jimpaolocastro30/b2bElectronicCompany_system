PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/erp_b2b

# Comma-separated list
CORS_ORIGINS=http://localhost:5173

ACCESS_TOKEN_SECRET=change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# Allow first admin creation via /auth/register when no admin exists
ALLOW_ADMIN_BOOTSTRAP=true

# ERP sync shared secret
ERP_SYNC_KEY=change-me

# SMTP (optional; if not set, OTP will be logged to console)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com
